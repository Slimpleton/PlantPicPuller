{
  "compilerOptions": {
    "target": "ES2022",
    "module": "EsNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "types":["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
},
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}